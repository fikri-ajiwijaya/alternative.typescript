{
	"customizations": {
		"vscode": {
			"extensions": [
				"ms-azuretools.vscode-containers"
			]
		}
	},
	"dockerComposeFile": "compose.yaml",
	"initializeCommand": "echo 'COMPOSE_PROJECT_NAME=${localWorkspaceFolderBasename}' > .env",
	"service": "alternative",
	"workspaceFolder": "/workspaces/${localWorkspaceFolderBasename}"
}
